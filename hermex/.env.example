# ═══════════════════════════════════════════════════════════════════
# Hermex Configuration
# ═══════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────
# LLM provider — auto-detected in this order:
#   1. OPENAI_API_KEY        → OpenAI (recommended, cheap + reliable)
#   2. ANTHROPIC_API_KEY     → Anthropic Claude
#   3. OPENROUTER_API_KEY    → OpenRouter (default Hermes-3)
#   4. HERMES_API_URL+KEY    → custom OpenAI-compatible endpoint
#
# Only fill in ONE of these. The rest can stay blank.
# ────────────────────────────────────────────────────────

# ── Option A: OpenAI (pay-as-you-go, gpt-4o-mini ~ $0.15/M tokens) ──
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Override model if you want (default: gpt-4o-mini)
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=gpt-4.1-mini

# ── Option B: Anthropic Claude ──
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-3-5-haiku-20241022

# ── Option C: OpenRouter (many models, needs credits) ──
# OPENROUTER_API_KEY=
# LLM_MODEL=nousresearch/hermes-3-llama-3.1-405b

# ── Option D: custom OpenAI-compatible endpoint ──
# HERMES_API_URL=http://localhost:3001/v1
# HERMES_API_KEY=

# Force a specific provider regardless of which keys are set
# (openai | anthropic | openrouter | custom)
# LLM_PROVIDER=openai

# ────────────────────────────────────────────────────────
# X / Twitter data source
# ────────────────────────────────────────────────────────
# Optional — if you have an X API bearer token (Basic tier $100/mo),
# it's used first. Otherwise falls back to RSSHub → Nitter (free).
# X_BEARER_TOKEN=

# Override RSSHub instance (defaults to https://rsshub.app)
# RSSHUB_BASE=https://rsshub.app

# How often to refresh the live markets feed (ms, default 10 min)
# FEED_REFRESH_MS=600000

# ────────────────────────────────────────────────────────
# Predict.fun
# ────────────────────────────────────────────────────────
PREDICT_FUN_API_URL=https://api-testnet.predict.fun
PREDICT_FUN_API_KEY=

# ────────────────────────────────────────────────────────
# Server
# ────────────────────────────────────────────────────────
PORT=6088
NODE_ENV=production
