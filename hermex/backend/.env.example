# Hermex Backend Configuration

# Server
PORT=6088
NODE_ENV=development

# LLM Provider — pick one:
# Option 1: OpenRouter (recommended, supports Hermes models)
OPENROUTER_API_KEY=your-key-here
LLM_MODEL=nousresearch/hermes-3-llama-3.1-405b

# Option 2: OpenAI-compatible endpoint (local Hermes, vLLM, etc.)
# HERMES_API_URL=http://localhost:8000/v1
# HERMES_API_KEY=
# LLM_MODEL=hermes-3

# Predict.fun
PREDICT_FUN_API_URL=https://api-testnet.predict.fun
PREDICT_FUN_API_KEY=
